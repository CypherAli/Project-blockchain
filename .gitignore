# ─── Node modules ──────────────────────────────────────────────
node_modules/

# ─── Environment variables (NEVER commit these!) ──────────────
.env
.env.local
.env.*.local
blockchain/.env
indexer/.env

# ─── Hardhat build artifacts ───────────────────────────────────
blockchain/artifacts/
blockchain/cache/
blockchain/typechain-types/
blockchain/deployments/

# ─── Next.js build ─────────────────────────────────────────────
frontend/.next/
frontend/out/

# ─── Indexer build ─────────────────────────────────────────────
indexer/dist/

# ─── Prisma generated (regenerate with prisma generate) ────────
# Note: schema.prisma IS committed; only generated client is ignored
indexer/node_modules/.prisma/

# ─── Frontend generated ABIs (copied by deploy script) ─────────
# Commit these so others can run without deploying first:
# frontend/lib/abis/  ← intentionally NOT ignored

# ─── OS / editor ────────────────────────────────────────────────
.DS_Store
Thumbs.db
*.log
.vscode/
.idea/

# ─── Coverage ───────────────────────────────────────────────────
coverage/
coverage.json

# ─── Docker ─────────────────────────────────────────────────────
# Docker volumes are managed by Docker, not Git
# No files to ignore here

# ─── Vercel ─────────────────────────────────────────────────────
.vercel
