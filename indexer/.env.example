# ArtCurve Indexer — Environment Variables
# Copy to .env and fill in your values

# ─── Required ─────────────────────────────────────────────────────────────────

# PostgreSQL connection string
# Local Docker: postgresql://postgres:localpass@localhost:5432/artcurve
# Supabase:     postgresql://postgres:[password]@[host]:5432/postgres
DATABASE_URL=postgresql://postgres:localpass@localhost:5432/artcurve

# Ethereum RPC endpoint
# Local Hardhat: http://127.0.0.1:8545
# Sepolia Alchemy: https://eth-sepolia.g.alchemy.com/v2/YOUR_KEY
RPC_URL=http://127.0.0.1:8545

# ArtFactory contract address (from deployment)
FACTORY_ADDRESS=0x5FbDB2315678afecb367f032d93F642f64180aa3

# ─── Optional ─────────────────────────────────────────────────────────────────

# Chain ID (31337=hardhat, 11155111=sepolia, 80002=polygon-amoy, 84532=base-sepolia)
CHAIN_ID=31337

# Block number to start indexing from (0 = genesis, use deployment block for efficiency)
START_BLOCK=0

# API port
API_PORT=3001

# Block polling interval in ms
POLL_INTERVAL_MS=3000

# Number of blocks to fetch per getLogs batch
LOGS_BATCH_SIZE=2000

# Frontend URL for CORS (leave empty to allow all origins in dev)
FRONTEND_URL=http://localhost:3000
