# ArtCurve Go Indexer — Environment Variables
# Copy to .env and fill in values for local development.
# Railway / Docker inject these directly as env vars.

# ─── Required ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:localpass@localhost:5432/artcurve
RPC_URL=http://127.0.0.1:8545
FACTORY_ADDRESS=0x5FbDB2315678afecb367f032d93F642f64180aa3

# ─── Optional (defaults shown) ────────────────────────────────────────────────
CHAIN_ID=31337
START_BLOCK=0
API_PORT=3001
POLL_INTERVAL_MS=3000
LOGS_BATCH_SIZE=2000
FRONTEND_URL=http://localhost:3000
NODE_ENV=development
